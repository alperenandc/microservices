{
  "id": null,
  "uid": "dispatcher-overview",
  "title": "Dispatcher Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests / Second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(dispatcher_http_requests_total[1m]))",
          "legendFormat": "all requests"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(dispatcher_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (5xx)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(dispatcher_http_requests_total{status_code=~\"5..\"}[1m])) / sum(rate(dispatcher_http_requests_total[1m]))",
          "legendFormat": "5xx ratio"
        }
      ]
    }
  ]
}
